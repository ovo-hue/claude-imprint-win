# Imprint runtime secrets & environment.
#
# Copy to <IMPRINT_DATA_DIR>\imprint.env  (default: %USERPROFILE%\.imprint\imprint.env)
# and fill in your values. This file lives in the DATA dir, outside the git
# repo, so your token is never committed. start.ps1 and cron-task.ps1 load it
# and pass these to the heartbeat, Telegram, and dashboard services.

# --- Telegram (optional) ---
# Bot token from @BotFather, your chat id from @userinfobot.
# NOTE: you must send your bot a message once (press Start) before it can
# message you, otherwise the API returns "chat not found".
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Locale ---
# UTC offset for timestamps/quiet-hours (e.g. 8 for China, -5 for US East).
TZ_OFFSET=0

# --- Network proxy (optional) ---
# If you reach Telegram / Anthropic through a local proxy, set these. urllib,
# httpx and the claude CLI honor them. Keep local services direct via NO_PROXY.
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
# NO_PROXY=localhost,127.0.0.1,::1

# --- Ombre Brain memory (optional) ---
# If you run the Ombre Brain memory server locally, the heartbeat/cron read its
# surfaced memory from this endpoint to make messages context-aware. Default:
# OMBRE_BREATH_URL=http://localhost:8000/breath-hook
